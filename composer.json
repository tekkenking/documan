{
    "name": "tekkenking/documan",
    "description": "An image manager for laravel",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/http": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/filesystem": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/contracts": "^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "pestphp/pest": "^3.0",
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "phpstan/phpstan": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Tekkenking\\Documan\\": "src/"
        },
        "files": [
            "src/DocumanHelpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tekkenking\\Documan\\Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Temitayo",
            "email": "bucketcodes@gmail.com"
        }
    ],
    "extra": {
        "laravel": {
            "providers": [
                "Tekkenking\\Documan\\DocumanServiceProvider"
            ],
            "aliases": {
                "Documan": "DocumanFacade"
            }
        }
    }
}
